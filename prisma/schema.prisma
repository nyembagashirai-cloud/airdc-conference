generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth ───────────────────────────────────────────────────────────────────
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(VIEWER)
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

enum Role {
  SUPER_ADMIN
  ADMIN
  EDITOR
  VIEWER
}

// ─── Conference / Events ─────────────────────────────────────────────────────
model Conference {
  id          String   @id @default(cuid())
  edition     Int      @default(23)
  title       String
  theme       String
  tagline     String?
  startDate   DateTime
  endDate     DateTime
  venue       String
  city        String   @default("Harare")
  country     String   @default("Zimbabwe")
  description String?  @db.Text
  brochureUrl String?
  isActive    Boolean  @default(true)
  sessions    ProgrammeSession[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ProgrammeSession {
  id           String    @id @default(cuid())
  conferenceId String
  conference   Conference @relation(fields: [conferenceId], references: [id])
  day          String     // "Day 1", "Day 2", etc.
  date         DateTime
  startTime    String
  endTime      String
  title        String
  subtitle     String?
  description  String?   @db.Text
  type         String    @default("PLENARY")
  venue        String?
  capacity     Int?
  speakers     SessionSpeaker[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

// ─── Speakers ────────────────────────────────────────────────────────────────
model Speaker {
  id           String   @id @default(cuid())
  name         String
  title        String?
  organisation String
  country      String?
  bio          String?  @db.Text
  photoUrl     String?
  photoPublicId String?
  email        String?
  linkedinUrl  String?
  twitter      String?
  website      String?
  speakerType  String   @default("Panel Speaker")
  featured     Boolean  @default(false)
  active       Boolean  @default(true)
  order        Int      @default(0)
  sessions     SessionSpeaker[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model SessionSpeaker {
  sessionId String
  speakerId String
  role      String?  // "Keynote Speaker", "Moderator", "Panelist"
  session   ProgrammeSession @relation(fields: [sessionId], references: [id])
  speaker   Speaker          @relation(fields: [speakerId], references: [id])
  @@id([sessionId, speakerId])
}

// ─── Sponsors ────────────────────────────────────────────────────────────────
model Sponsor {
  id          String      @id @default(cuid())
  name        String
  tier        String      @default("GOLD")
  logoUrl     String?
  logoPublicId String?
  website     String?
  description String?     @db.Text
  contactName String?
  contactEmail String?
  order       Int         @default(0)
  active      Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

// ─── News / Articles ─────────────────────────────────────────────────────────
model Article {
  id          String      @id @default(cuid())
  title       String
  slug        String      @unique
  excerpt     String?
  content     String      @db.Text
  coverImage  String?
  coverPublicId String?
  category    String      @default("NEWS")
  published   Boolean     @default(false)
  publishedAt DateTime?
  tags        String[]
  authorName  String?
  authorTitle String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

// ─── Gallery ─────────────────────────────────────────────────────────────────
model GalleryAlbum {
  id          String   @id @default(cuid())
  title       String
  description String?
  coverImage  String?
  year        Int      @default(2026)
  order       Int      @default(0)
  images      GalleryImage[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model GalleryImage {
  id          String       @id @default(cuid())
  albumId     String
  album       GalleryAlbum @relation(fields: [albumId], references: [id], onDelete: Cascade)
  url         String
  publicId    String?
  caption     String?
  altText     String?
  order       Int          @default(0)
  createdAt   DateTime     @default(now())
}

// ─── Registrations ───────────────────────────────────────────────────────────
model Registration {
  id              String   @id @default(cuid())
  firstName       String
  lastName        String
  email           String
  phone           String?
  organisation    String
  jobTitle        String
  country         String
  delegateType    String
  civility        String?
  passportId      String?
  companyAddress  String?
  branchOfActivity String?
  visaInvitation  String?
  arrivalDate     String?
  arrivalTime     String?
  departureDate   String?
  departureTime   String?
  airlineCompany  String?
  flightNumber    String?
  dietaryRequirements String?
  specialNeeds    String?
  workshopChoice  String?
  paymentStatus   PaymentStatus @default(PENDING)
  paymentRef      String?
  amount          Float?
  confirmationCode String?  @unique
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

enum DelegateType {
  DELEGATE
  SPEAKER
  SPONSOR
  PRESS
  ORGANISER
  VIP
}

enum PaymentStatus {
  PENDING
  PAID
  WAIVED
  CANCELLED
}

// ─── Contact / Feedback ──────────────────────────────────────────────────────
model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String   @db.Text
  type      ContactType @default(GENERAL)
  status    String   @default("NEW")
  createdAt DateTime @default(now())
}

enum ContactType {
  GENERAL
  SPONSORSHIP
  MEDIA
  LOGISTICS
  SPEAKER_INQUIRY
  FEEDBACK
}

// ─── Analytics ───────────────────────────────────────────────────────────────
model PageView {
  id        String   @id @default(cuid())
  page      String
  userAgent String?
  ip        String?
  referrer  String?
  country   String?
  createdAt DateTime @default(now())
  @@index([page])
  @@index([createdAt])
}

// ─── Hotels ──────────────────────────────────────────────────────────────────
model Hotel {
  id           String   @id @default(cuid())
  name         String
  stars        Int      @default(4)
  address      String
  city         String   @default("Harare")
  phone        String?
  email        String?
  website      String?
  bookingUrl   String?
  imageUrl     String?
  description  String?  @db.Text
  featured     Boolean  @default(false)
  order        Int      @default(0)
  rates        HotelRate[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model HotelRate {
  id        String   @id @default(cuid())
  hotelId   String
  hotel     Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  roomType  String
  rateUSD   Float
  ratePer   String   @default("night")
  includes  String?
  available Boolean  @default(true)
}
